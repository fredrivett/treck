---
import { ExploreLoader } from '../../components/ExploreLoader';
import Base from '../../layouts/Base.astro';
import { parseGitHubUrl } from '../../lib/explore-utils';

export const prerender = false;

const repoParam = Astro.url.searchParams.get('repo') ?? '';
const parts = repoParam.split('/');
const owner = parts[0] ?? '';
const repo = parts[1] ?? '';
const isValid = owner && repo && /^[a-zA-Z0-9._-]+$/.test(owner) && /^[a-zA-Z0-9._-]+$/.test(repo);

if (!isValid) {
  return Astro.redirect('/showcases');
}

const displayName = `${owner}/${repo}`;
const repoUrl = `https://github.com/${owner}/${repo}`;
---

<Base title={`${displayName} — Treck`} description={`Interactive dependency graph of ${displayName}, generated by treck.`}>
	<div class="h-screen flex flex-col bg-background text-foreground">
		<nav class="flex items-center justify-between px-6 py-3 border-b border-border shrink-0">
			<div class="flex items-center gap-4">
				<a href="/" class="font-mono text-sm font-medium tracking-tight text-foreground">treck</a>
				<span class="text-muted-foreground/40">/</span>
				<a href="/showcases" class="font-mono text-sm text-muted-foreground hover:text-foreground transition-colors">showcases</a>
				<span class="text-muted-foreground/40">/</span>
				<span class="font-mono text-sm text-foreground">{displayName}</span>
			</div>
			<a
				href={repoUrl}
				class="font-mono text-xs text-muted-foreground hover:text-foreground transition-colors"
				target="_blank"
				rel="noopener noreferrer"
			>
				View source &rarr;
			</a>
		</nav>
		<div class="flex-1 overflow-hidden">
			<ExploreLoader
				client:only="react"
				repo={`${owner}/${repo}`}
			/>
		</div>
	</div>
</Base>
