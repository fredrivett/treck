---
import { ShowcaseLoader } from '../../components/ShowcaseLoader';
import Base from '../../layouts/Base.astro';
import { showcases } from '../../showcases';

export function getStaticPaths() {
  return showcases.map((project) => ({
    params: { project: project.slug },
    props: project,
  }));
}

const { slug, name, description, repo } = Astro.props;
---

<Base title={`${name} — Treck Showcase`} description={`Interactive flow graph of ${name}, generated by treck.`}>
	<div class="h-screen flex flex-col bg-background text-foreground">
		<nav class="flex items-center justify-between px-6 py-3 border-b border-border shrink-0">
			<div class="flex items-center gap-4">
				<a href="/" class="font-mono text-sm font-medium tracking-tight text-foreground">treck</a>
				<span class="text-muted-foreground/40">/</span>
				<a href="/showcases" class="font-mono text-sm text-muted-foreground hover:text-foreground transition-colors">showcases</a>
				<span class="text-muted-foreground/40">/</span>
				<span class="font-mono text-sm text-foreground">{name}</span>
			</div>
			<a
				href={repo}
				class="font-mono text-xs text-muted-foreground hover:text-foreground transition-colors"
				target="_blank"
				rel="noopener noreferrer"
			>
				View source &rarr;
			</a>
		</nav>
		<div class="flex-1 overflow-hidden">
			<ShowcaseLoader
				client:only="react"
				graphUrl={`/showcases/${slug}.json`}
				project={slug}
			/>
		</div>
	</div>
</Base>
