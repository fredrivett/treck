---
import Nav from '../../components/Nav.astro';
import { PopularRepos } from '../../components/PopularRepos';
import { RepoSearchBar } from '../../components/RepoSearchBar';
import Base from '../../layouts/Base.astro';
import { showcases } from '../../showcases';
---

<Base title="Showcases — Treck" description="See treck in action on popular TypeScript projects.">
	<div class="min-h-screen flex flex-col">
		<Nav active="showcases" />

		<main class="flex-1 px-6 pt-12 sm:pt-16 max-w-3xl mx-auto w-full">
			<h1 class="font-mono text-3xl font-bold tracking-tight mb-3">Showcases</h1>
			<p class="text-muted-foreground text-sm mb-10 max-w-lg">
				See how treck maps real-world TypeScript projects. Explore a curated showcase below, or paste any GitHub URL to try your own.
			</p>

			<RepoSearchBar client:load />

			<PopularRepos client:load />

			<div class="grid gap-px bg-border">
				{showcases.map((project) => (
					<a
						href={`/showcases/${project.slug}`}
						class="block bg-background p-6 hover:bg-muted/50 transition-colors group"
					>
						<div class="flex items-start justify-between">
							<div>
								<h2 class="font-mono font-medium text-base text-foreground/90 group-hover:text-foreground transition-colors">
									{project.name}
								</h2>
								<p class="text-sm text-muted-foreground mt-1">{project.description}</p>
							</div>
							<span class="font-mono text-xs text-muted-foreground/60 group-hover:text-muted-foreground transition-colors mt-1">
								&rarr;
							</span>
						</div>
					</a>
				))}
			</div>
		</main>

		<footer class="py-8 text-center text-xs font-mono text-muted-foreground/40">
			<p>MIT License &middot; Built by <a href="https://github.com/fredrivett" class="text-muted-foreground hover:text-foreground transition-colors">@fredrivett</a></p>
		</footer>
	</div>
</Base>
