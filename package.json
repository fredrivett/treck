{
  "name": "treck",
  "version": "0.2.3",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "main": "dist/index.mjs",
  "bin": {
    "treck": "./dist/index.mjs"
  },
  "scripts": {
    "dev": "bash scripts/run.sh",
    "dev:cli": "tsdown src/cli/index.ts --watch",
    "build": "tsdown src/cli/index.ts && pnpm run build:viewer",
    "build:viewer": "vite build --config src/server/viewer/vite.config.ts",
    "treck": "node dist/index.mjs",
    "test": "vitest",
    "test:extractor": "tsx scripts/test-extractor.ts",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "format:unsafe": "biome check --write --unsafe .",
    "website": "pnpm --filter @treck/website dev",
    "website:build": "pnpm --filter @treck/website build",
    "website:preview": "pnpm --filter @treck/website preview"
  },
  "keywords": [],
  "author": "@fredrivett",
  "license": "ISC",
  "description": "Docs that automatically sync with your code",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@biomejs/biome": "^2.3.13",
    "@changesets/cli": "^2.29.8",
    "@tailwindcss/postcss": "^4.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/marked": "^5.0.2",
    "@types/node": "^25.3.5",
    "@types/picomatch": "^4.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@xyflow/react": "^12.10.0",
    "beautiful-mermaid": "^1.0.2",
    "clsx": "^2.1.1",
    "elkjs": "^0.11.0",
    "fake-indexeddb": "^6.2.5",
    "lucide-react": "^0.574.0",
    "marked": "^17.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "tsdown": "^0.20.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "usehooks-ts": "^3.1.1",
    "vaul": "^1.1.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@clack/prompts": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "ai": "^6.0.116",
    "cac": "^6.7.14",
    "class-variance-authority": "^0.7.1",
    "idb": "^8.0.3",
    "motion": "^12.35.0",
    "picomatch": "^4.0.3",
    "radix-ui": "^1.4.3",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
